{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}