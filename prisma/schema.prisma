generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  manager
  contributor
}

enum ContentType {
  post
  video
  reel
  carousel
}

enum ContentStatus {
  planned
  in_progress
  review
  done
  published
}

enum Priority {
  low
  medium
  high
}

enum Platform {
  LinkedIn
  X
  Instagram
  TikTok
  YouTube
  Facebook
}

enum ActivityEntityType {
  content
  product
}

enum ActivityAction {
  created
  updated
  status_changed
  assigned
  deleted
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdContent  ContentItem[] @relation("CreatedContent")
  assignedContent ContentItem[] @relation("AssignedContent")
  activityLogs    ActivityLog[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contentItems ContentItem[]
}

model ContentItem {
  id            String        @id @default(uuid())
  title         String
  description   String
  type          ContentType
  productId     String
  status        ContentStatus @default(planned)
  platforms     Platform[]
  scheduledDate DateTime?
  publishedDate DateTime?
  createdById   String
  assignedToId  String
  priority      Priority
  tags          String[]
  mediaUrl      String?
  notes         String?
  // Fractional ordering: repeated bisection between two rows will eventually exhaust float precision.
  // If the gap becomes too small, a periodic rebalance (reassigning order values) will be needed.
  order         Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  product    Product @relation(fields: [productId], references: [id])
  createdBy  User    @relation("CreatedContent", fields: [createdById], references: [id])
  assignedTo User    @relation("AssignedContent", fields: [assignedToId], references: [id])

  activityLogs ActivityLog[]

  @@index([productId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([order])
}

model ActivityLog {
  id            String             @id @default(uuid())
  entityType    ActivityEntityType
  entityId      String
  contentItemId String?
  action        ActivityAction
  previousValue Json?
  newValue      Json?
  changedById   String
  timestamp     DateTime           @default(now())

  changedBy   User         @relation(fields: [changedById], references: [id])
  contentItem ContentItem?  @relation(fields: [contentItemId], references: [id])
}